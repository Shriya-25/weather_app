{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Weather App (Chrome)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--dart-define=OPENWEATHER_API_KEY=${input:openWeatherApiKey}"
      ]
    },
    {
      "name": "Weather App (Edge)",
      "request": "launch",
      "type": "dart",
      "deviceId": "edge",
      "toolArgs": [
        "--dart-define=OPENWEATHER_API_KEY=${input:openWeatherApiKey}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "openWeatherApiKey",
      "type": "promptString",
      "description": "Enter your OpenWeather API key"
    }
  ]
}
